package app.main

import std.array
import std.io

fn main() -> void {
    let mut items: Array<i32> = Array.new<i32>()
    items.push(1)
    items.push(2)
    items.set(0, 7)
    let first: Option<i32> = items.get(0)
    let message: string = match first {
        Some(value) => if value == 7 {
            "array ok"
        } else {
            "wrong"
        }
        None => "missing"
    }
    io.println(message)
}

package app.main

import std.array
import std.io

fn main() -> void {
    let mut values: Array<string> = Array.new<string>()
    values.push("if let ok")
    let first: Option<string> = values.get(0)
    if let Some(message) = first {
        io.println(message)
    } else {
        io.println("missing value")
    }
}

package app.main

import std.io

pub interface Display {
    fn to_string(self) -> string
}

struct User {
    name: string
}

impl Display for User {
    fn to_string(self) -> string {
        return self.name
    }
}

fn display<T: Display>(value: T) -> void {
    io.println(value.to_string())
}

fn main() -> void {
    let user: User = User { name: "interface display ok" }
    display<User>(user)
}

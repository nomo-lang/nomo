package app.main

import std.array.new
import std.io.println

fn main() -> void {
    let mut items: Array<i32> = new<i32>()
    items.push(7)
    let first: Option<i32> = items.get(0)
    let message: string = match first {
        Option.Some(value) => if value == 7 {
            "specific array new ok"
        } else {
            "wrong"
        }
        Option.None => "missing"
    }
    println(message)
}

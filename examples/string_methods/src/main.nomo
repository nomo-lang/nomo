package app.main

import std.io
import std.string

fn main() -> void {
    let prefix: string = "string "
    let message: string = prefix.concat("methods ok")
    let output: string = if message.len() == 17 {
        if message == "string methods ok" {
            if message != "wrong" {
                message
            } else {
                "wrong"
            }
        } else {
            "wrong"
        }
    } else {
        "wrong"
    }
    io.println(output)
}
